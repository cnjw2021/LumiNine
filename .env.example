# Docker Compose (dev) で PostgreSQL に渡す環境変数
# 使い方: このファイルを .env にコピーし、必要に応じて値を変更してください。
# cp .env.example .env

DB_NAME=luminine
DB_USER=superuser
DB_PASSWORD=superpass!
DB_HOST=postgres
DB_PORT=5432

# ── GitHub Actions / Cloud Run デプロイ用 Secrets (GitHub で設定) ──
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ACCOUNT_ID=
# CF_PAGES_PROJECT_NAME=luminine-frontend

# GCP_SA_KEY=<base64 エンコードされたサービスアカウント JSON>
# GCP_PROJECT_ID=your-gcp-project-id
# GCP_REGION=asia-northeast1
# GCP_SERVICE_NAME=luminine-backend

# DATABASE_URL=postgresql+psycopg2://user:password@host:5432/dbname
# SECRET_KEY=
# JWT_SECRET_KEY=
# SUPERUSER_EMAIL=
# SUPERUSER_PASSWORD=

# フロントエンド
# NEXT_PUBLIC_API_URL=https://your-cloudrun-service.run.app
